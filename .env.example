# ============================================
# Crypto Whale Screener - Configuration
# ============================================

# Telegram Bot
TELEGRAM_BOT_TOKEN=1234567890:ABCdefGHIjklMNOpqrsTUVwxyz
TELEGRAM_ADMIN_ID=123456789

# Binance API (опционально)
BINANCE_API_KEY=
BINANCE_API_SECRET=

# Ethereum RPC (для DEX)
ETH_RPC_URL=https://mainnet.infura.io/v3/YOUR_PROJECT_ID

# Настройки
LOG_LEVEL=INFO
WHITELIST_ADDRESSES=0x1234...,0x5678...
BLACKLIST_ADDRESSES=0xabcd...,0xefgh...

# Database (опционально)
DATABASE_URL=sqlite+aiosqlite:///whale_screener.db

# ============================================
# Production Variables (для Railway)
# ============================================

# Environment
NODE_ENV=production
RAILWAY_ENVIRONMENT=production

# ============================================
# Telegram Bot (для Railway)
# ============================================

# Telegram Bot Token (получите от @BotFather)
TELEGRAM_BOT_TOKEN=your_bot_token_here

# Telegram Admin ID (ваш Telegram user ID)
# Узнать: @userinfobot в Telegram
TELEGRAM_ADMIN_ID=123456789

# ============================================
# Frontend Variables (для сборки)
# ============================================

# WebSocket URL (в production используйте ваш домен)
# NEXT_PUBLIC_WS_URL=wss://your-app.railway.app/api/signals/ws

# Backend API URL (в production используйте ваш домен)
# NEXT_PUBLIC_API_URL=https://your-app.railway.app/api